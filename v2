<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>梨子訂購單</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;700&family=Noto+Sans+TC:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green-dark: #3a6b35;
    --green-mid: #4e8a3e;
    --green-light: #e8f0e6;
    --orange-dark: #c0621a;
    --orange-mid: #d97c2a;
    --orange-light: #fdf0e3;
    --orange-border: #e8a060;
    --cream: #fdfaf5;
    --ink: #2a2a1e;
    --muted: #7a7a6a;
    --line: #d8d0c0;
  }

  @media print {
    body { background: white; }
    .page { box-shadow: none; margin: 0; max-width: 100%; }
  }

  body {
    background: #e8e0d0;
    background-image: 
      radial-gradient(circle at 20% 20%, rgba(78,138,62,0.08) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(201,122,42,0.08) 0%, transparent 50%);
    font-family: 'Noto Sans TC', sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 32px 16px;
  }

  .page {
    background: var(--cream);
    width: 100%;
    max-width: 680px;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.08);
    overflow: hidden;
    position: relative;
  }

  /* ── 頂部裝飾帶 ── */
  .top-band {
    height: 6px;
    background: linear-gradient(90deg, var(--green-dark), var(--green-mid) 50%, var(--orange-mid));
  }

  /* ── 標題區 ── */
  .header {
    padding: 28px 32px 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .brand-icon {
    width: 52px;
    height: 52px;
    background: linear-gradient(135deg, var(--green-mid), var(--green-dark));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    flex-shrink: 0;
  }

  .brand-text {
    font-family: 'Noto Serif TC', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--green-dark);
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  .brand-sub {
    font-size: 11px;
    color: var(--muted);
    font-weight: 300;
    letter-spacing: 0.1em;
    margin-top: 2px;
  }

  /* 日期欄 */
  .date-row {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--ink);
  }

  .date-row label { color: var(--muted); white-space: nowrap; }

  .date-input {
    border: none;
    border-bottom: 1.5px solid var(--line);
    background: transparent;
    font-family: 'Noto Sans TC', sans-serif;
    font-size: 13px;
    color: var(--ink);
    padding: 2px 4px;
    outline: none;
    transition: border-color 0.2s;
    text-align: center;
  }

  .date-input:focus { border-bottom-color: var(--green-mid); }
  .date-input.year { width: 52px; }
  .date-input.month { width: 36px; }
  .date-input.day { width: 36px; }

  /* ── 分隔線 ── */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--line) 15%, var(--line) 85%, transparent);
    margin: 20px 32px 0;
  }

  /* ── 主體雙欄 ── */
  .body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 20px 32px;
  }

  .col-left { padding-right: 16px; border-right: 1px solid var(--line); }
  .col-right { padding-left: 16px; }

  /* ── 區塊標題 ── */
  .section-title {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: 'Noto Serif TC', serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 7px 12px;
    border-radius: 3px;
    margin-bottom: 12px;
  }

  .section-title.green {
    background: var(--green-dark);
    color: white;
  }

  .section-title.orange {
    background: var(--orange-dark);
    color: white;
  }

  .section-title .icon { font-size: 16px; }

  /* ── 表格 ── */
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
  }

  thead th {
    padding: 6px 8px;
    font-weight: 500;
    font-size: 11.5px;
    letter-spacing: 0.05em;
    border-bottom: 1.5px solid currentColor;
  }

  .green-table thead th {
    color: var(--green-dark);
    border-bottom-color: var(--green-mid);
  }

  .orange-table thead th {
    color: var(--orange-dark);
    border-bottom-color: var(--orange-mid);
  }

  tbody tr {
    border-bottom: 1px solid var(--line);
    transition: background 0.15s;
  }

  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: rgba(78,138,62,0.04); }

  td {
    padding: 5px 8px;
    color: var(--ink);
    vertical-align: middle;
  }

  .td-badge {
    width: 28px;
    text-align: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    font-size: 11px;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .badge.green { background: var(--green-mid); }
  .badge.orange { background: var(--orange-mid); }

  .td-name { color: var(--ink); }

  .td-qty { width: 52px; text-align: right; }

  .qty-input {
    width: 44px;
    border: none;
    border-bottom: 1.5px solid var(--line);
    background: transparent;
    font-family: 'Noto Sans TC', sans-serif;
    font-size: 13px;
    color: var(--ink);
    text-align: center;
    padding: 1px 2px;
    outline: none;
    transition: border-color 0.2s;
  }

  .qty-input:focus { border-bottom-color: var(--green-mid); }

  /* checkbox 欄 */
  .checkbox-col {
    width: 28px;
    text-align: center;
  }

  input[type="checkbox"] {
    width: 14px;
    height: 14px;
    accent-color: var(--green-mid);
    cursor: pointer;
  }

  /* ── 舒果網（直網）區 ── */
  .straight-net-section {
    margin-top: 16px;
  }

  /* ── 備註區 ── */
  .notes-section {
    margin: 0 32px 24px;
  }

  .notes-label {
    font-family: 'Noto Serif TC', serif;
    font-size: 12px;
    font-weight: 700;
    color: var(--orange-dark);
    border-left: 3px solid var(--orange-mid);
    padding-left: 8px;
    margin-bottom: 8px;
    letter-spacing: 0.05em;
  }

  .notes-input {
    width: 100%;
    height: 72px;
    border: 1.5px solid var(--orange-border);
    border-radius: 3px;
    background: var(--orange-light);
    font-family: 'Noto Sans TC', sans-serif;
    font-size: 13px;
    color: var(--ink);
    padding: 8px 12px;
    outline: none;
    resize: vertical;
    transition: border-color 0.2s;
  }

  .notes-input:focus { border-color: var(--orange-mid); }

  /* ── 底部語錄 ── */
  .footer {
    background: linear-gradient(135deg, var(--green-light), var(--orange-light));
    border-top: 1px solid var(--line);
    padding: 16px 32px;
    text-align: center;
  }

  .footer-quote {
    font-family: 'Noto Serif TC', serif;
    font-size: 15px;
    color: var(--green-dark);
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1.8;
  }

  .footer-tagline {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.15em;
    margin-top: 4px;
  }

  /* ── 列印按鈕 ── */
  .btn-row {
    display: flex;
    gap: 10px;
    margin: 0 32px 20px;
  }

  .print-btn, .png-btn {
    flex: 1;
    padding: 11px;
    border: none;
    border-radius: 3px;
    font-family: 'Noto Sans TC', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }

  .print-btn {
    background: var(--green-dark);
    color: white;
  }
  .print-btn:hover { background: var(--green-mid); }

  .png-btn {
    background: var(--orange-dark);
    color: white;
  }
  .png-btn:hover { background: var(--orange-mid); }

  .print-btn:active, .png-btn:active { transform: scale(0.99); }

  @media print { .btn-row { display: none; } }

  /* ── 響應式 ── */
  @media (max-width: 520px) {
    .body { grid-template-columns: 1fr; }
    .col-left { padding-right: 0; border-right: none; border-bottom: 1px solid var(--line); padding-bottom: 20px; margin-bottom: 20px; }
    .col-right { padding-left: 0; }
    .header { flex-direction: column; }
  }
</style>
</head>
<body>

